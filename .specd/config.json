{
  "version": 1,
  "defaultVerify": "php artisan test",
  "report": {
    "format": "md",
    "autoRefreshSeconds": 0
  },
  "roles": {
    "subagentMode": "delegate"
  },
  "promotionThreshold": 3,
  "gates": {
    "traceability": "warn",
    "acceptance": "off",
    "scope": "off",
    "contextBudget": "off",
    "maxContextTokens": 0,
    "modeCapability": "",
    "custom": []
  },
  "verify": {
    "sandbox": "none"
  },
  "orchestration": {
    "enabled": true,
    "approvalPolicy": "planning",
    "workerMode": "host",
    "maxWorkers": 4,
    "maxRetries": 2,
    "sessionTimeoutMinutes": 120,
    "hostReportedCostLimitUSD": 0,
    "transport": {
      "kind": "file",
      "pollIntervalMillis": 500,
      "messageTTLSeconds": 3600,
      "leaseSeconds": 120,
      "heartbeatSeconds": 30
    },
    "program": {
      "maxConcurrentSpecs": 2
    }
  },
  "mcp": {
    "expose": "",
    "essentialTools": null,
    "includeMeta": false,
    "includeOrchestration": null
  }
}
